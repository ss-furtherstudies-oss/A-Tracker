generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Enums are replaced by Strings for SQLite compatibility
// Role: ADMIN, STAFF, STUDENT
// Gender: MALE, FEMALE, OTHER
// StudentStatus: APPLICANT, ENROLLED, GRADUATED, ALUMNI, WITHDRAWN
// ScholarshipType: ..., NONE
// ApplicationStatus: DRAFT, ...
// DecisionType: OFFER, ...

model Person {
  id                String   @id @default(uuid())
  name_en           String
  name_zh           String?
  dob               DateTime
  gender            String   @default("OTHER")
  contact_info      String?  // General address/contact
  national_id       String   @unique
  phone             String?
  social_media_urls Json?    // { ig: "link", linkedin: "link" }

  // Relations
  user              User?
  studentProfile    StudentProfile?
  applications      Application[]
  communicationLogs CommunicationLog[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model User {
  id            String   @id @default(uuid())
  person_id     String   @unique
  username      String   @unique
  password_hash String
  role          String   @default("STUDENT")
  is_active     Boolean  @default(true)

  person        Person   @relation(fields: [person_id], references: [id])
  decisionsMade AdmissionDecision[] @relation("DecisionMaker")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Program {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  level       String
  department  String
  duration    Int      // Duration in years/months

  applications   Application[]
  studentProfiles StudentProfile[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model StudentProfile {
  id               String          @id @default(uuid())
  person_id        String          @unique
  student_num      String          @unique
  status           String          @default("APPLICANT")
  entry_term       String
  program_id       String
  scholarship_type String          @default("NONE")
  grad_year        Int?

  person        Person        @relation(fields: [person_id], references: [id])
  program       Program       @relation(fields: [program_id], references: [id])
  alumniProfile AlumniProfile?
  igcse_score      String?
  ias_score        String?
  alevel_score     String?
  ielts_score      String?
  university_dest  String?       // E.g., Oxford, Cambridge
  program_dest     String?       // E.g., Mathematics, Computer Science

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Application {
  id                  String            @id @default(uuid())
  person_id           String
  program_id          String
  status              String            @default("DRAFT")
  submission_date     DateTime?
  offer_accepted_bool Boolean           @default(false)

  person        Person                @relation(fields: [person_id], references: [id])
  program       Program               @relation(fields: [program_id], references: [id])
  decisions     AdmissionDecision[]
  documents     ApplicationDocument[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AdmissionDecision {
  id              String       @id @default(uuid())
  application_id  String
  type            String
  date            DateTime     @default(now())
  maker_id        String
  scholarship_amt Float?

  application Application @relation(fields: [application_id], references: [id])
  maker       User        @relation("DecisionMaker", fields: [maker_id], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApplicationDocument {
  id             String  @id @default(uuid())
  application_id String
  doc_type       String
  file_url       String
  is_verified    Boolean @default(false)

  application Application @relation(fields: [application_id], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AlumniProfile {
  id                 String  @id @default(uuid())
  student_profile_id String  @unique
  grad_term          String
  employer           String?
  industry           String?
  mentor_flag        Boolean @default(false)

  studentProfile StudentProfile @relation(fields: [student_profile_id], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CommunicationLog {
  id        String   @id @default(uuid())
  person_id String
  channel   String   // EMAIL, SMS, WHATSAPP
  direction String   // INBOUND, OUTBOUND
  subject   String
  timestamp DateTime @default(now())

  person Person @relation(fields: [person_id], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  entityName  String   // Person, StudentProfile, AdmissionDecision
  entityId    String
  action      String   // PATCH, DELETE
  userId      String?  // Who made the change
  changes     Json     // The payload of changes
  createdAt   DateTime @default(now())
}
